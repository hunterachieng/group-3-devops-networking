# ---------------------------------------------------------------------------
# .env.example — copy to .env and fill in values before running the stack.
#
#   cp .env.example .env
#
# .env is gitignored and must never be committed.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Docker Hub — required for publishing and production deployment
# ---------------------------------------------------------------------------

# Your Docker Hub username (also set as a GitHub Actions Variable)
DOCKERHUB_USERNAME=your-dockerhub-username

# The repo/app name — defaults to the current directory name in deploy.sh
# Override if you run the deploy script from a different location
APP_NAME=group-3-devops-networking

# Pinned image tag to deploy — must be a sha-<7-char-hash> produced by CI
# Never use: latest, main, dev, or any branch name
IMAGE_TAG=sha-a1b2c3d

# ---------------------------------------------------------------------------
# Service runtime — used by docker-compose.prod.yml
# ---------------------------------------------------------------------------

# Internal service URLs (Compose DNS names — do not change unless renaming services)
INVENTORY_URL=http://inventory:3002
PAYMENT_URL=http://payment:3003
ORDER_URL=http://order:3001

# Seconds before a downstream HTTP call is abandoned
DOWNSTREAM_TIMEOUT=5

# ---------------------------------------------------------------------------
# Alerting — Slack delivery via Alertmanager
# ---------------------------------------------------------------------------

# Incoming Webhook URL for #group-3-alerts (Slack → Apps → Incoming Webhooks).
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/HERE
